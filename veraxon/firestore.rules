rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Veraxon AI Assessment Platform — Firestore Security Rules
// ─────────────────────────────────────────────────────────────────────────────
// IMPORTANT: We do NOT use get() inside rules to avoid circular permission
// errors. Role checks use request.auth.token.role (custom claims) where
// available, with safe fallbacks for the users collection itself.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth()   { return request.auth != null; }
    function uid()      { return request.auth.uid; }
    function isOwner(id){ return isAuth() && uid() == id; }

    // Role from custom claims (set via Admin SDK) — falls back to 'student'
    function role()     { return isAuth() ? request.auth.token.get('role', 'student') : ''; }
    function isAdmin()  { return role() == 'admin'; }
    function isStaff()  { return role() == 'staff' || role() == 'admin'; }
    function isStudent(){ return role() == 'student'; }

    // ── /users/{userId} ──────────────────────────────────────────────────────
    // A user can always read/write their own document.
    // Staff/admin can read all user docs for candidate management.
    match /users/{userId} {
      allow read:   if isOwner(userId) || isStaff();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── /tests/{testId} ──────────────────────────────────────────────────────
    match /tests/{testId} {
      allow read:   if isAuth() && (
                      isStaff() ||
                      resource.data.status == 'published'
                    );
      allow create: if isStaff();
      allow update: if isAdmin() || (isStaff() && resource.data.createdBy == uid());
      allow delete: if isAdmin() || (isStaff() && resource.data.createdBy == uid());
    }

    // ── /exams/{examId} ──────────────────────────────────────────────────────
    match /exams/{examId} {
      allow read:   if isAuth();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ── /assessments/{id} ────────────────────────────────────────────────────
    match /assessments/{id} {
      allow read:   if isAuth() && (isStaff() || resource.data.status == 'published');
      allow create: if isStaff();
      allow update: if isAdmin() || (isStaff() && resource.data.createdBy == uid());
      allow delete: if isAdmin() || (isStaff() && resource.data.createdBy == uid());
    }

    // ── /assignments/{id} ────────────────────────────────────────────────────
    // Students read assignments that include their uid in assignedTo array.
    match /assignments/{id} {
      allow read:   if isAuth() && (
                      isStaff() ||
                      uid() in resource.data.assignedTo
                    );
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin() || isStaff();
    }

    // ── /submissions/{id} ────────────────────────────────────────────────────
    match /submissions/{id} {
      allow read:   if isAuth() && (
                      isStaff() ||
                      resource.data.userId == uid()
                    );
      allow create: if isAuth() && request.resource.data.userId == uid();
      allow update: if isAuth() && (isStaff() || resource.data.userId == uid());
      allow delete: if isAdmin();
    }

    // ── /infractions/{id} ────────────────────────────────────────────────────
    match /infractions/{id} {
      allow read:   if isAuth() && (isStaff() || resource.data.studentId == uid());
      allow create: if isAuth();   // camera component + API route write here
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ── /violations/{id} ─────────────────────────────────────────────────────
    match /violations/{id} {
      allow read:   if isAuth() && (isStaff() || resource.data.studentId == uid());
      allow create: if isAuth();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ── /results/{id} ────────────────────────────────────────────────────────
    match /results/{id} {
      allow read:   if isAuth() && (isStaff() || resource.data.studentId == uid());
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ── /notifications/{id} ──────────────────────────────────────────────────
    match /notifications/{id} {
      allow read:   if isAuth() && (
                      resource.data.recipientId == uid() ||
                      resource.data.userId == uid() ||
                      isAdmin()
                    );
      allow create: if isStaff() || isAdmin();
      allow update: if isAuth() && (resource.data.recipientId == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.recipientId == uid() || isAdmin());
    }

    // ── /sessions/{id} ───────────────────────────────────────────────────────
    match /sessions/{id} {
      allow read:   if isAuth() && (isStaff() || resource.data.status == 'active');
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ── /studentSessions/{id} ────────────────────────────────────────────────
    match /studentSessions/{id} {
      allow read:   if isAuth() && (isStaff() || resource.data.studentId == uid());
      allow create: if isAuth() && request.resource.data.studentId == uid();
      allow update: if isStaff() || resource.data.studentId == uid();
      allow delete: if isAdmin();
    }

    // ── /questionBanks/{id} ──────────────────────────────────────────────────
    match /questionBanks/{id} {
      allow read:   if isAuth();
      allow create: if isStaff();
      allow update: if isAdmin() || (isStaff() && resource.data.createdBy == uid());
      allow delete: if isAdmin() || (isStaff() && resource.data.createdBy == uid());
    }

    // ── /departments & /colleges ─────────────────────────────────────────────
    match /departments/{id} { allow read: if isAuth(); allow write: if isAdmin(); }
    match /colleges/{id}    { allow read: if isAuth(); allow write: if isAdmin(); }

    // ── /activityLogs & /stats ───────────────────────────────────────────────
    match /activityLogs/{id} { allow read: if isAdmin(); allow write: if false; }
    match /stats/{id}        { allow read: if isAuth();  allow write: if false; }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
